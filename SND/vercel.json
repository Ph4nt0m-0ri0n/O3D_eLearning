{
  "headers": [
    {
      "source": "/(.*)\\.(glb|gltf|bin|hdr)$",
      "headers": [
        {
          "key": "Content-Encoding",
          "value": "identity"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
